#:culture{:id "smr.dish.torta-tre-monti", :name "Torta Tre Monti", :country "SMR", :kind :dish, :summary "Traditional Sammarinese wafer-layer cake bound with chocolate or hazelnut creme and covered in chocolate fondant, its name (\"Cake of the Three Mountains/Towers\") representing the Three Towers of San Marino; the San Marino Wikipedia article calls it the country's best-known dish.", :url "https://en.wikipedia.org/wiki/Torta_Tre_Monti", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "smr.dish.piadina", :name "Piadina", :country "SMR", :kind :dish, :summary "Flatbread described by the San Marino Wikipedia article as \"a dish characteristic of the Italian region of Romagna and of San Marino\" -- an honestly shared regional dish, not exclusive to San Marino.", :url "https://en.wikipedia.org/wiki/San_Marino", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "smr.beverage.sammarinese-wine", :name "Sammarinese wine", :country "SMR", :kind :beverage, :summary "San Marino's small but profitable wine industry, producing red wines Brugneto and Tessano and white wines Biancale and Roncale from grapevines cultivated on its slopes for nearly 2000 years; about 6,500 hectolitres are produced yearly, roughly 85% sold domestically.", :url "https://en.wikipedia.org/wiki/Sammarinese_wine", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "smr.festival.feast-of-saint-marinus", :name "Feast of Saint Marinus and the Republic", :country "SMR", :kind :festival, :summary "National feast held 3 September, celebrating the traditional origin of the Republic of San Marino in AD 301, per the public-holidays table in the San Marino Wikipedia article.", :url "https://en.wikipedia.org/wiki/San_Marino", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "smr.heritage.historic-centre-mount-titano", :name "San Marino Historic Centre and Mount Titano", :country "SMR", :kind :heritage, :summary "55-hectare property including Mount Titano and San Marino's historic centre -- fortification towers (Guaita, Cesta, Montale), walls, gates, a 19th-century basilica and Palazzo Pubblico; inscribed as a UNESCO World Heritage Site in 2008 as testimony to the continuity of a free republic since the Middle Ages.", :url "https://en.wikipedia.org/wiki/Monte_Titano", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
